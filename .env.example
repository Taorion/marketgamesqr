PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-us-west-2.pooler.supabase.com:6543/postgres
DB_SSL=true
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h
PUBLIC_VALIDATOR_URL=http://localhost:3000/validador
PUBLIC_APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
ENABLE_DEMO_TOOLS=true
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_WEBHOOK_URL=
MOTO_BUSINESS_ID=replace-with-business-id
MOTO_GAME_ID=replace-with-game-id
MOTO_REWARD_ID=replace-with-reward-id
MOTO_CAMPAIGN_ID=
PRODUCT_CAMPAIGN_ID=

# Used by npm run seed
SEED_ADMIN_EMAIL=admin@marketgames.local
SEED_ADMIN_PASSWORD=replace-with-demo-admin-password
SEED_BUSINESS_NAME=Demo Store
SEED_OWNER_EMAIL=owner@marketgames.local
SEED_OWNER_PASSWORD=replace-with-demo-owner-password
SEED_VALIDATOR_EMAIL=validator@marketgames.local
SEED_VALIDATOR_PASSWORD=replace-with-demo-validator-password
